# server/ reads these (copy to server/.env for local dev)
# Runtime connection (for hosted PG like Neon, use the POOLED endpoint here)
DATABASE_URL="postgresql://medistore:medistore_dev@localhost:5432/medistore"
# Optional: direct (non-pooler) endpoint for prisma migrate on hosted PG (Neon etc.)
# DIRECT_DATABASE_URL="postgresql://user:pass@host-without-pooler/db?sslmode=require"
JWT_SECRET="change-me-in-production"
ADMIN_EMAIL="admin@medistore.local"
ADMIN_PASSWORD="change-me-admin"
# comma-separated browser origins allowed by CORS (client, admin)
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"
# comma-separated delivery areas served in v1
SERVED_AREAS="Dhanmondi"
DELIVERY_FEE_BDT="60"
# same-day cutoff hour (24h clock, local time) shown at checkout
DELIVERY_CUTOFF_HOUR="18"
SUPPORT_PHONE="01XXXXXXXXX"

# client/ and admin/ (Next.js) — copy into client/.env.local and admin/.env.local
NEXT_PUBLIC_API_URL="http://localhost:3001"
